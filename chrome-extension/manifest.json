{
  "manifest_version": 3,
  "name": "Donee",
  "version": "1.0.0",
  "key": "",
  "description": "Manage tasks and projects from anywhere.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Donee"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://*.supabase.co/*"]
}
